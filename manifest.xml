<?xml version="1.0" encoding="UTF-8"?>
<!--
  Window Slider — PowerPoint content add-in
  ==========================================
  BEFORE INSTALLING: replace every occurrence of  YOUR-HOST  below with the
  host where you upload this folder (e.g.  window-slider-abc123.netlify.app ).
  There are 5 of them: AppDomain, IconUrl, HighResolutionIconUrl, SupportUrl,
  and SourceLocation. Do a find-and-replace on "YOUR-HOST".
  The GUID in <Id> is already generated for you — leave it as is.
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="ContentApp">

  <Id>c083d9ef-6a8e-4cb5-be71-632fd5f92c06</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Ryan Fredette</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Window Slider" />
  <Description DefaultValue="Interactive image-comparison slider for radiology windowing. Drag to reveal one image over another — live, during your presentation. Supports side-by-side or top/bottom orientation." />

  <IconUrl DefaultValue="https://YOUR-HOST/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://YOUR-HOST/icon-80.png" />
  <SupportUrl DefaultValue="https://YOUR-HOST/" />

  <AppDomains>
    <AppDomain>https://YOUR-HOST</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Presentation" />
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://YOUR-HOST/index.html" />
    <RequestedWidth>720</RequestedWidth>
    <RequestedHeight>540</RequestedHeight>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

</OfficeApp>
